# Recallium Python Edition - Environment Configuration
# Copy this file to .env and customize your settings
# The Makefile will automatically load these settings

# ============================================================================
# Timezone Configuration (Optional)
# ============================================================================
# Set container timezone to sync with host time for accurate job scheduling
# Examples: America/New_York, Europe/London, Asia/Tokyo, UTC
# Leave commented to auto-detect or default to UTC
TZ=America/New_York

# ============================================================================
# Logging Configuration
# ============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================================================
# LLM Configuration
# ============================================================================

# API Keys (only needed for cloud providers)
# For production: Store in vault instead of .env
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AZURE_API_KEY=
AZURE_ENDPOINT=

# ============================================================================
# Container Configuration
# ============================================================================
# Container and image names
CONTAINER_NAME=recallium-python
# VERSION is managed in ../VERSION file and read by Makefile (don't set here)

# Recallium edition: community or enterprise
RECALLIUM_EDITION=community

# Environment: development or production
ENVIRONMENT=production

# ============================================================================
# Host Port Mappings (External Access)
# ============================================================================
# These control how ports are mapped from your host machine to the container
# Example: HOST_UI_PORT=9001 means access UI at http://localhost:9001
# Container internal ports are FIXED (API:8000, UI:9000, DB:5432)

HOST_API_PORT=8001
HOST_UI_PORT=9001
HOST_POSTGRES_PORT=5433

# External UI URL (used in MCP responses to tell clients where to access UI)
# Should match your HOST_UI_PORT mapping above
UI_BASE_URL=http://localhost:9001


# ============================================================================
# Processing Configuration
# ============================================================================

# Number of uvicorn workers for API server
# Recommendations: 1-2 for development, 2-4 for production
WORKERS=2

# Memory processor worker pool configuration
# Controls concurrent memory processing (embedding, tagging, clustering)
# Lower for local LLMs (Ollama), higher for cloud APIs
MEMORY_PROCESSOR_MIN_WORKERS=5
MEMORY_PROCESSOR_MAX_WORKERS=30

# ============================================================================
# Data Configuration
# ============================================================================

# Load sample memories and projects on first startup
# true: Loads sample memories for testing (first run only)
# false: Start with empty database
LOAD_SAMPLE_DATA=false

# ============================================================================
# Database Configuration
# ============================================================================

# Python app database config (pydantic-settings uses these field names)
DB_HOST=localhost
DB_PORT=5432
DB_USER=recallium
DB_PASSWORD=recallium_password
DB_NAME=recallium_memories

# ============================================================================
# Embedding Configuration
# ============================================================================

# Embedding model (local sentence-transformers)
# Nomic-embed-text-v1.5: 768 dimensions, 8192 token context, ARM64 compatible
EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5

# Embedding dimensions - must match the model's output
# Common values: 768 (nomic, bge-base), 1024 (bge-large), 1536 (OpenAI)
EMBEDDING_DIM=768

# Pin model to specific revision for security (prevents auto-download of new code)
# Get revision hash from: https://huggingface.co/nomic-ai/nomic-embed-text-v1.5/commits/main
# Leave empty to use latest (will show warnings about new files)
EMBEDDING_MODEL_REVISION=

# HuggingFace/Transformers cache and offline settings
# Model is pre-downloaded during Docker build
# Set HF_HUB_OFFLINE=1 for air-gapped environments (requires model in cache)
# For normal operation, leave disabled - library will use cache without re-downloading
#HF_HUB_OFFLINE=1
#TRANSFORMERS_OFFLINE=1
# Nomic uses nomic-bert-2048 base model which requires trust_remote_code
TRUST_REMOTE_CODE=1

# Embedding computation device
# Options: cpu (default), cuda (if available)
EMBEDDING_DEVICE=cpu

# HuggingFace model cache directory (must match Dockerfile's HF_HOME)
HF_HOME=/app/.cache/huggingface

# ============================================================================
# Ollama Configuration (for LLM, not embeddings)
# ============================================================================

# Ollama service URL
# Options:
#   Docker Desktop/Podman: http://host.docker.internal:11434 (recommended)
#   Linux host: http://172.17.0.1:11434
#   Remote Ollama: http://your-ollama-server:11434
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ============================================================================
# Document Upload & Chunking Configuration
# ============================================================================

# Document chunk size in tokens (uses BERT tokenizer)
# Constraint: MUST NOT exceed embedding model's context window
# Nomic context: 8192 tokens (safe to use larger chunks)
CHUNK_SIZE_TOKENS=1024

# Document chunk overlap in tokens
# Recommendations: 10-15% of chunk size
CHUNK_OVERLAP_TOKENS=128

# Parallel threads for document chunk embedding
# 1 for Ollama, 5-10 for local CPU, 20-30 for cloud APIs
EMBEDDING_CONCURRENT_THREAD_POOL=5

# Retry configuration for embedding requests
EMBEDDING_MAX_RETRIES=3
EMBEDDING_RETRY_DELAY_MS=1000

# ============================================================================
# Vault Configuration (Secrets Management)
# ============================================================================
# Recallium uses an encrypted vault for API keys and sensitive data
# Vault backend is determined by ENVIRONMENT variable (above):
#   - development: encrypted file at ./data/vault/vault.enc
#   - community/production: encrypted file at /secrets/vault.enc (separate volume)

# Vault storage path (default: /secrets for Docker, ./data/vault for dev)
# VAULT_PATH=/secrets

# Vault passphrase for encryption (key derived via PBKDF2)
# CRITICAL: Change this in production!
# For Docker: pass via -e VAULT_PASSPHRASE=yourpassphrase
VAULT_PASSPHRASE=recallium-dev-passphrase


# ============================================================================
# Document Storage
# ============================================================================

# Document storage path (mounted as separate Docker volume)
DOCUMENT_STORAGE_PATH=/documents

# ============================================================================
# CORS Configuration
# ============================================================================
# Allowed origins for API requests (JSON array format for pydantic-settings v2)
CORS_ORIGINS=["http://localhost:9001","http://localhost:3000","http://localhost:8001"]

# ============================================================================
# User Configuration
# ============================================================================

# Default user ID for single-user mode
# Future: Will be replaced with OAuth/SSO user ID in multi-user mode
DEFAULT_USER_ID=system

# ============================================================================
# Volume Names
# ============================================================================

# Docker volumes for persistent data
# Schema version suffix - bump when DB schema has breaking changes
# Warning: 'make clean-volume' will delete these volumes and all data!
# Note: WAL and DOCS volumes are derived in Makefile as $(VOLUME_NAME)-wal and $(VOLUME_NAME)-docs
VOLUME_NAME=recallium-v1
